# Recommended: keeps login sessions stable across restarts.
FLASK_SECRET_KEY=change_me_to_a_long_random_value

# Mark session cookies Secure when the UI is served over HTTPS (e.g. behind a reverse proxy).
# SESSION_COOKIE_SECURE=1

# DEBUG should be off in production.
DEBUG=False
HOST=0.0.0.0
PORT=5000
SQUID_CONFIG_PATH=/etc/squid/squid.conf
CERTS_DIR=/etc/squid/ssl/certs
CACHE_DIR=/var/cache/squid
LOG_DIR=/var/log/squid
LOG_LEVEL=info

# Multi-container control plane (current deployment model).
# DEFAULT_PROXY_ID=default
# PROXY_INSTANCE_ID=default
# PROXY_DISPLAY_NAME=Default Proxy
# PROXY_MANAGEMENT_TOKEN=change_me_to_a_shared_internal_token
# PROXY_MANAGEMENT_URL=http://proxy:5000
# PROXY_PUBLIC_HOST=proxy.example.lan
# Optional override when the direct PAC URL differs from http://<PROXY_PUBLIC_HOST>/proxy.pac.
# PROXY_PUBLIC_PAC_URL=http://proxy.example.lan/proxy.pac
# PROXY_PUBLIC_PAC_SCHEME=http
# PROXY_PUBLIC_PAC_PORT=80
# PROXY_PUBLIC_HTTP_PROXY_PORT=3128

# Disable IPv6 inside the container and bind published ports on IPv4 only.
DISABLE_IPV6=1

# Optional explicit Squid overrides.
# If blank, the persisted/template Squid config remains authoritative and the
# entrypoint will no longer overwrite UI-applied values on restart.
# MAX_WORKERS=4
# SQUID_WORKERS=1
# SQUID_CACHE_MEM_MB=256
# SQUID_SSLCRTD_CHILDREN=  # default: 2 x workers
# SQUID_DYNAMIC_CERT_MEM_CACHE_MB=  # default: 128 x workers, capped at 512
# SQUID_MAX_FILEDESCRIPTORS=        # default: max(65536, workers * 32768)

# Optional observability poll intervals.
# Increase these when you prefer lower idle CPU over near-real-time log/UI updates.
# LIVE_STATS_POLL_INTERVAL_SECONDS=2.0
# DIAGNOSTIC_POLL_INTERVAL_SECONDS=2.0
# SSL_ERRORS_POLL_INTERVAL_SECONDS=2.0

# Gunicorn (admin UI) scaling knobs.
# The sane low-footprint default is 1 worker / 2 threads.
# WEB_WORKERS=1
# WEB_THREADS=2
# WEB_TIMEOUT=120
# WEB_GRACEFUL_TIMEOUT=30
# WEB_KEEPALIVE=5

# Remote ClamAV daemon used by the local AV c-icap service.
# Replace with the host/IP where clamd is running.
# The proxy-local AV c-icap listener still binds on CICAP_AV_PORT and forwards scans to this backend.
# CICAP_PORT=14000
# CICAP_AV_PORT=14001
CLAMD_HOST=127.0.0.1
CLAMD_PORT=3310

# External database (required runtime backend; MySQL 8+ only).
# Leave DATABASE_URL empty when using the discrete MYSQL_* variables.
# SQLite and in-place legacy schema migrations are no longer supported.
# Example URL form: mysql+pymysql://user:password@host:3306/squid_proxy
# DATABASE_URL=
# MYSQL_HOST=192.168.1.10
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=change_me
# MYSQL_DATABASE=squid_proxy
# MYSQL_CREATE_DATABASE=1
# MYSQL_CONNECT_TIMEOUT=10
# MYSQL_READ_TIMEOUT=15
# MYSQL_WRITE_TIMEOUT=15

# Optional: raise file descriptor limit for high concurrency
ULIMIT_NOFILE=

# Web-filter external ACL helper concurrency. Leave blank to derive from Squid workers (2 x workers).
WEBFILTER_HELPERS=

# Per-process idle MySQL connection cache size. Leave blank to derive a safer default from container concurrency.
DB_POOL_SIZE=

# Proxy runtime control-plane cadence. Leave sync at 30s unless you need slower propagation.
# The heartbeat is intentionally slower by default because the proxy now hash-gates heavy state checks.
# PROXY_HEARTBEAT_INTERVAL_SECONDS=90
# PROXY_SYNC_INTERVAL_SECONDS=30

# Web filtering is configured via the admin UI (Policy → Web Filtering).
