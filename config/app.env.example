# Recommended: keeps login sessions stable across restarts.
FLASK_SECRET_KEY=replace_with_a_long_random_value

# Mark session cookies Secure when the UI is served over HTTPS (e.g. behind a reverse proxy).
# SESSION_COOKIE_SECURE=1

# DEBUG should be off in production.
DEBUG=False
HOST=0.0.0.0
PORT=5000
SQUID_CONFIG_PATH=/etc/squid/squid.conf
CERTS_DIR=/etc/squid/ssl/certs
CACHE_DIR=/var/cache/squid
LOG_DIR=/var/log/squid
LOG_LEVEL=info

# Multi-container control plane (current deployment model).
# DEFAULT_PROXY_ID=default
# PROXY_INSTANCE_ID=default
# PROXY_DISPLAY_NAME=Default Proxy
# PROXY_MANAGEMENT_TOKEN=replace_with_a_shared_internal_token
# Optional full override. If unset, the proxy registers http://<PROXY_MANAGEMENT_HOST or PROXY_PUBLIC_HOST or dns-safe PROXY_INSTANCE_ID>:5000.
# PROXY_MANAGEMENT_URL=http://proxy:5000
# PROXY_MANAGEMENT_HOST=proxy
# PROXY_MANAGEMENT_SCHEME=http
# PROXY_MANAGEMENT_PORT=5000
# PROXY_PUBLIC_HOST=proxy.example.lan
# Optional override when the direct PAC URL differs from http://<PROXY_PUBLIC_HOST>/proxy.pac.
# The generated PAC metadata preserves custom paths and query strings such as /wpad.dat?site=lab.
# PROXY_PUBLIC_PAC_URL=http://proxy.example.lan/proxy.pac
# PROXY_PUBLIC_PAC_SCHEME=http
# PROXY_PUBLIC_PAC_PORT=80
# PAC_HTTP_HOST=0.0.0.0
# PAC_HTTP_PORT=80
# Local-only Squid forwarding health canary. Keep bound to loopback; it is not exposed by compose.
# FORWARDING_CANARY_HOST=127.0.0.1
# FORWARDING_CANARY_PORT=18080
# FORWARDING_CANARY_PATH=/__docker_proxy_forwarding_canary
# PROXY_PUBLIC_HTTP_PROXY_PORT=3128
# Optional comma-separated CIDRs whose X-Forwarded-For/X-Real-IP headers may select PAC profiles.
# Leave blank when clients request PAC/WPAD directly.
# PAC_TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128

# Optional NAT intercept listeners. These only make Squid listen; router/host
# REDIRECT or DNAT rules must send TCP/80 and/or TCP/443 traffic to these ports.
# Do not advertise these listeners in PAC files or expose them directly to untrusted clients.
# SQUID_HTTP_PORT=3128
# SQUID_INTERCEPT_ENABLED=0
# SQUID_INTERCEPT_PORT=3129
# PROXY_PUBLIC_INTERCEPT_PORT=3129
# SQUID_HTTPS_INTERCEPT_ENABLED=0
# SQUID_HTTPS_INTERCEPT_PORT=3130
# SQUID_HTTPS_INTERCEPT_SPLICE_ONLY=0
# PROXY_PUBLIC_HTTPS_INTERCEPT_PORT=3130

# Disable IPv6 inside the container and bind published ports on IPv4 only.
DISABLE_IPV6=1

# Optional explicit Squid overrides.
# If blank, the persisted/template Squid config remains authoritative and the
# entrypoint will no longer overwrite UI-applied values on restart.
# MAX_WORKERS=4
# SQUID_WORKERS=1
# SQUID_CACHE_MEM_MB=256
# SQUID_SSLCRTD_CHILDREN=  # default: 2 x workers
# SQUID_DYNAMIC_CERT_MEM_CACHE_MB=  # default: 128 x workers, capped at 512
# SQUID_MAX_FILEDESCRIPTORS=        # default: max(65536, workers * 32768)
# PROXY_SHM_SIZE=512m               # keep >= cache_mem + dynamic cert cache headroom

# Optional observability cadence, backoff, and bounded pending-row knobs.
# Increase poll/commit intervals when you prefer lower idle CPU over near-real-time log/UI updates.
# Pending-row caps protect RAM while MySQL writes are backed off; live max is clamped to at least LIVE_STATS_COMMIT_BATCH.
# LIVE_STATS_COMMIT_BATCH=200
# LIVE_STATS_COMMIT_INTERVAL_SECONDS=5.0
# LIVE_STATS_POLL_INTERVAL_SECONDS=2.0
# LIVE_STATS_MAX_PENDING_ROWS=5000
# LIVE_STATS_DB_WRITE_BACKOFF_INITIAL_SECONDS=5.0
# LIVE_STATS_DB_WRITE_BACKOFF_MAX_SECONDS=120.0
# LIVE_STATS_DB_WRITE_BACKOFF_JITTER_RATIO=0.2
# DIAGNOSTIC_COMMIT_BATCH=400
# DIAGNOSTIC_COMMIT_INTERVAL_SECONDS=5.0
# DIAGNOSTIC_POLL_INTERVAL_SECONDS=2.0
# DIAGNOSTIC_PENDING_MAX_ROWS=5000
# DIAGNOSTIC_DB_WRITE_BACKOFF_INITIAL_SECONDS=5.0
# DIAGNOSTIC_DB_WRITE_BACKOFF_MAX_SECONDS=120.0
# DIAGNOSTIC_DB_WRITE_BACKOFF_JITTER_RATIO=0.2
# TIMESERIES_ROLLUP_INTERVAL_SECONDS=300.0
# TIMESERIES_STARTUP_JITTER_SECONDS=15.0
# TIMESERIES_SAMPLE_DB_BACKOFF_INITIAL_SECONDS=5.0
# TIMESERIES_SAMPLE_DB_BACKOFF_MAX_SECONDS=120.0
# TIMESERIES_SAMPLE_DB_BACKOFF_JITTER_RATIO=0.2
# TIMESERIES_ROLLUP_DB_BACKOFF_INITIAL_SECONDS=30.0
# TIMESERIES_ROLLUP_DB_BACKOFF_MAX_SECONDS=300.0
# TIMESERIES_ROLLUP_DB_BACKOFF_JITTER_RATIO=0.2
# SSL_ERRORS_COMMIT_BATCH=300
# SSL_ERRORS_COMMIT_INTERVAL_SECONDS=5.0
# SSL_ERRORS_POLL_INTERVAL_SECONDS=2.0
# STATS_CACHE_DIR_SIZE_TTL_SECONDS=300

# Gunicorn (admin UI) scaling knobs.
# The sane low-footprint default is 1 worker / 2 threads.
# WEB_WORKERS=1
# WEB_THREADS=2
# WEB_TIMEOUT=120
# WEB_GRACEFUL_TIMEOUT=30
# WEB_KEEPALIVE=5
# ADMIN_UI_HTTPS_ENABLED=0
# ADMIN_UI_SSL_CERTFILE and ADMIN_UI_SSL_KEYFILE are internal bootstrap
# fallbacks for custom launchers. The packaged UI toggle generates
# /etc/squid/ssl/certs/admin-ui.crt and admin-ui.key from the active
# generated/uploaded SSL inspection CA bundle mounted at /etc/squid/ssl/certs.

# Remote ClamAV daemon used by the local AV c-icap service.
# Replace with the host/IP where clamd is running.
# The proxy-local AV c-icap request/upload listener still binds on CICAP_AV_PORT and forwards scans to this backend.
# For remote clamd, response/download scanning uses a separate local ICAP helper;
# leave CICAP_AV_RESP_PORT blank to place it after the request/upload worker range.
# CICAP_PORT=14000
# CICAP_AV_PORT=14001
# CICAP_AV_RESP_PORT=
CLAMD_HOST=127.0.0.1
CLAMD_PORT=3310

# Adblock helper sizing and ICAP request handling. Leave blank for runtime defaults.
# ADBLOCK_CACHE_TTL=3600
# ADBLOCK_CACHE_MAX=200000
# ADBLOCK_RULE_CACHE_MAX=50000
# ADBLOCK_ICAP_MAX_REQUEST_BYTES=262144
# ADBLOCK_ICAP_MAX_BODY_DRAIN_BYTES=8388608
# ADBLOCK_ICAP_REQUEST_TIMEOUT=5.0
# ADBLOCK_ICAP_MAX_KEEPALIVE_REQUESTS=1000

# External database (required runtime backend; MySQL 8+ only).
# Leave DATABASE_URL empty when using the discrete MYSQL_* variables.
# SQLite and in-place legacy schema migrations are no longer supported.
# Example URL form: mysql+pymysql://user:password@host:3306/squid_proxy
# DATABASE_URL=
# MYSQL_HOST=192.168.1.10
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=replace_with_the_database_password
# MYSQL_DATABASE=squid_proxy
# MYSQL_CREATE_DATABASE=1
# MYSQL_CONNECT_TIMEOUT=10
# MYSQL_READ_TIMEOUT=15
# MYSQL_WRITE_TIMEOUT=15
# MYSQL_CONNECT_RETRIES=4
# MYSQL_CONNECT_RETRY_DELAY_SECONDS=0.2
# MYSQL_LOCK_WAIT_TIMEOUT=10
# MYSQL_INNODB_LOCK_WAIT_TIMEOUT=10
# MYSQL_SESSION_WAIT_TIMEOUT=300
# MYSQL_TRANSACTION_ISOLATION=READ COMMITTED
# DB_POOL_ACQUIRE_TIMEOUT_SECONDS=30
# DB_POOL_MAX_IDLE_SECONDS=45
# PROXY_HEALTH_UI_TIMEOUT_SECONDS=5
# PROXY_CLAMAV_HEALTH_UI_TIMEOUT_SECONDS=5
# PROXY_HEALTH_UI_CACHE_TTL_SECONDS=10
# PROXY_OBSERVABILITY_UI_CACHE_TTL_SECONDS=15
# PROXY_HEALTH_CACHE_TTL_SECONDS=10
# PROXY_CLAMAV_HEALTH_PROBE_TIMEOUT_SECONDS=1.5

# Docker Compose log rotation defaults are read from the root .env/launch
# environment, not from mounted /config/app.env files. Keep these in root .env:
# DOCKER_LOG_DRIVER=json-file
# DOCKER_LOG_MAX_SIZE=10m
# DOCKER_LOG_MAX_FILE=3

# Optional: raise file descriptor limit for high concurrency
ULIMIT_NOFILE=

# Web-filter external ACL helper concurrency. Leave blank to derive from Squid workers (2 x workers).
WEBFILTER_HELPERS=

# Per-process idle MySQL connection cache size. Leave blank to derive from WEB_THREADS.
# Admin UI derives a minimum of 16 to keep request threads and background jobs
# from sharing a narrow pool; explicit values are capped by the app.
DB_POOL_SIZE=

# Bundled MySQL connection budget for docker-compose.mysql.yml. For external
# MySQL, set an equivalent server-side max_connections value.
MYSQL_MAX_CONNECTIONS=160
# Bundled MySQL packet budget for compiled adblock artifacts and larger policy
# snapshots. External MySQL deployments should set an equivalent server-side
# max_allowed_packet value.
MYSQL_MAX_ALLOWED_PACKET=256M

# Startup schema/DDL advisory lock wait. Prevents admin UI and proxy containers
# from racing CREATE/ALTER/DROP during cold starts and upgrades.
MYSQL_SCHEMA_LOCK_TIMEOUT_SECONDS=30

# Scheduled MySQL housekeeping keeps observability logs plus control-plane
# history bounded. These caps preserve active rows and recent history while
# pruning stale revision blobs, apply ledgers, terminal operations, old policy
# review rows, expired Safe Browsing cache rows, and maintenance-run history.
# MYSQL_CONTROL_PLANE_RETENTION_DAYS=90
# MYSQL_HOUSEKEEPING_KEEP_REVISIONS=25
# MYSQL_HOUSEKEEPING_KEEP_APPLICATIONS=200
# MYSQL_HOUSEKEEPING_KEEP_OPERATIONS=500
# MYSQL_HOUSEKEEPING_KEEP_POLICY_ROWS=1000
# MYSQL_HOUSEKEEPING_KEEP_MAINTENANCE_RUNS=20

# Proxy runtime control-plane cadence. Leave sync at 30s unless you need slower propagation.
# The heartbeat is intentionally slower by default because the proxy now hash-gates heavy state checks.
# Optional live-stack test mode. When enabled, the proxy shortens its default
# heartbeat/sync cadence only if you did not already set explicit interval vars.
# This flag does not run tests by itself; use docker-compose.live-tests.yml for that.
# ENABLE_TEST_MODE=1
# PROXY_HEARTBEAT_INTERVAL_SECONDS=90
# PROXY_SYNC_INTERVAL_SECONDS=30

# Web filtering is configured via the admin UI (Policy -> Web Filtering).
